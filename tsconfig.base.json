{
  "compilerOptions": {
    "target":            "ES2022",
    "module":            "ESNext",
    "moduleResolution":  "Bundler",
    "lib":               ["ES2022"],
    "esModuleInterop":   true,
    "skipLibCheck":      true,
    "strict":            true,
    "noUnusedLocals":    true,
    "noFallthroughCasesInSwitch": true,
    "forceConsistentCasingInFileNames": true,
    "declaration":       true,
    "declarationMap":    true,
    "sourceMap":         true,
    "resolveJsonModule": true,
    "isolatedModules":   true
  }
}
